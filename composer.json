{
    "name": "user-pixel-error/laravel-friendships",
    "description": "This package gives Eloquent models the ability to manage their friendships.",
    "keywords": [
        "laravel",
        "friendships",
        "friend-system",
        "friends",
        "eloquent"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "PixelError"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/events": "^12.0 || ^13.0",
        "illuminate/pagination": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.5 || ^12.0",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PixelError\\Friendships\\": "src/"
        },
        "files": [
            "src/Support/legacy_aliases.php"
        ]
    },
    "autoload-dev": {
        "files": [
            "tests/helpers.php"
        ],
        "classmap": [
            "tests/Stub_User.php"
        ],
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PixelError\\Friendships\\FriendshipsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "ci": [
            "@format:test",
            "@analyse",
            "@test"
        ]
    }
}
